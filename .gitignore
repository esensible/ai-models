# Python / virtualenv
cad/.venv/
cad/.home/
__pycache__/
*.pyc

# Generated artifacts — models, slices, previews are built, not committed
cad/out/
*.stl
*.3mf
*.gcode
*.png
*.jpg
*.jpeg

# Fonts are fetched (cad/fonts/fetch.sh), not vendored
cad/fonts/*.ttf
cad/fonts/*.otf

# Slicer profiles are regenerated from OrcaSlicer by slice/slice.sh
slice/profiles/

# Local printer/runtime state
bambu/loaded.json
bambu/snapshot.jpg

# Secrets / local config — never commit
*.env
*.key
id_*
*printer*
